<!DOCTYPE html>
<html>
<head>
    <title>Blockchain To-Do List</title>
</head>
<body style="font-family:Arial; margin:40px;">

<h1 style="color:blue;">Blockchain To-Do List</h1>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">

    <!-- Add Task -->
    <form action="/add" method="POST" style="display:flex; gap:10px;">
        <input
            type="text"
            name="task"
            placeholder="Enter a task"
            style="padding:10px; width:300px;"
            required
        >
        <button type="submit">Add Task</button>
    </form>

    <!-- Search -->
    <form action="/" method="GET" style="display:flex; gap:10px;">
        <input
            type="text"
            name="search"
            placeholder="Search task..."
            value="<%= search %>"
            style="padding:10px; width:250px;"
        >
        <button type="submit">Search</button>
    </form>

</div>

<h2>Statistics Dashboard</h2>

<p><strong>Total Tasks:</strong> <%= totalTasks %></p>
<p><strong>Completed Tasks:</strong> <%= completedTasks %></p>
<p><strong>Progress:</strong> <%= progress %>%</p>

<div style="width:600px; background:#ddd; border-radius:10px;">
    <div
        style="
        width:<%= progress %>%;
        background:green;
        color:white;
        padding:10px;
        border-radius:10px;
        ">
        <%= progress %>%
    </div>
</div>

<br>

<% if (blockchainValid) { %>
    <h3 style="color:green;">✅ Blockchain Verified</h3>
<% } else { %>
    <h3 style="color:red;">❌ Blockchain Corrupted</h3>
<% } %>

<h2>Tasks</h2>

<% chain.forEach((block, index) => { %>

<div style="
border:1px solid #ddd;
padding:20px;
margin-bottom:20px;
border-radius:10px;
">

    <h3>Block #<%= index %></h3>

    <p>
        <strong>Task:</strong>
        <%= block.data.task || block.data %>
    </p>

    <p>
        <strong>Status:</strong>
        <% if (block.completed) { %>
            ✅ Completed
        <% } else { %>
            ⏳ Pending
        <% } %>
    </p>

    <p>
        <strong>Timestamp:</strong>
        <%= block.timestamp %>
    </p>

    <p>
        <strong>Hash:</strong>
        <%= block.hash %>
    </p>

    <p>
        <strong>Previous Hash:</strong>
        <%= block.previousHash %>
    </p>

    <% if (index > 0) { %>

        <form
            action="/complete/<%= index %>"
            method="POST"
            style="display:inline;"
        >
            <button type="submit">
                Mark Completed
            </button>
        </form>

        <form
            action="/delete/<%= index %>"
            method="POST"
            style="display:inline;"
        >
            <button type="submit">
                Delete
            </button>
        </form>

    <% } %>

</div>

<% }) %>

</body>
</html>